# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el archivo .env con valores reales.

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DJANGO_SETTINGS_MODULE=config.settings.prod

# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# Render — hostname del servicio web (sin https://)
ALLOWED_HOSTS=admos-backend.onrender.com

# CORS — URL del frontend en Vercel (con https://)
CORS_ALLOWED_ORIGINS=https://admos.vercel.app

# Cloudinary — agregar manualmente, nunca commitear
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
