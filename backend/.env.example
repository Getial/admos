# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el archivo .env con valores reales.

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=True

# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://usuario:password@host/dbname?sslmode=require

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# CORS (frontend URL)
FRONTEND_URL=http://localhost:5173
